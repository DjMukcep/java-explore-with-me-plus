      "item": [
        {
          "name": "Добавление комментария к событию",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const main = async () => {",
                  "    const api = new API(pm);",
                  "    const rnd = new RandomUtils();",
                  "",
                  "    try {",
                  "        const user = await api.addUser(rnd.getUser());",
                  "        pm.collectionVariables.set(\"uid\", user.id);",
                  "",
                  "        const category = await api.addCategory(rnd.getCategory());",
                  "        pm.collectionVariables.set(\"catId\", category.id);",
                  "",
                  "        let eventBody = rnd.getEvent(category.id);",
                  "        eventBody['requestModeration'] = true",
                  "        eventBody['participantLimit'] = 0",
                  "",
                  "        let event = await api.addEvent(user.id, eventBody);",
                  "        event = await api.publishEvent(event.id);",
                  "        pm.collectionVariables.set(\"eventId\", event.id);",
                  "    } catch(err) {",
                  "        console.error(\"Ошибка при подготовке тестовых данных.\", err);",
                  "    }",
                  "};",
                  "",
                  "const interval = setInterval(() => {}, 1000);",
                  "",
                  "setTimeout(async () => ",
                  "    {",
                  "        try {",
                  "            await main();",
                  "        } catch (e) {",
                  "            console.error(e);",
                  "        } finally {",
                  "            clearInterval(interval);",
                  "        }",
                  "    },  ",
                  "    100 ",
                  ");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"Ответ должен содержать код статуса 201 и данные в формате json\", function () {",
                  "    pm.response.to.have.status(201);   ",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const target = pm.response.json();",
                  "var query = {};",
                  "pm.request.url.query.all().forEach((param) => { query[param.key] = param.value});",
                  "",
                  "pm.test(\"Ответ должен содержать поля: id, text, event, authorName, created\", function () {",
                  "pm.expect(target).to.have.property('id');",
                  "pm.expect(target).to.have.property('text');",
                  "pm.expect(target).to.have.property('authorId');",
                  "pm.expect(target).to.have.property('eventId');",
                  "pm.expect(target).to.have.property('authorName');",
                  "pm.expect(target).to.have.property('created');",
                  "});",
                  "",
                  "pm.test(\"Текст комментария в теле запроса и в теле ответа должны совпадать\", function () {",
                  "    pm.expect(json.text).to.eql(JSON.parse(pm.request.body.raw).text);",
                  "});",
                  "",
                  "pm.test(\"Поля ответа не должны быть пустыми или null\", function () {",
                  "    pm.expect(target.id).to.be.a('number').and.to.be.above(0);",
                  "    pm.expect(target.text).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(target.authorName).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(target.created).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(target.authorId).to.be.a('number').and.to.be.above(0);",
                  "    pm.expect(target.eventId).to.be.a('number').and.to.be.above(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"commentId\", target.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
