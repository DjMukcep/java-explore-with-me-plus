                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "const id1 = Number(pm.collectionVariables.get(\"expectedCommentId1\"));",
                  "const id2 = Number(pm.collectionVariables.get(\"expectedCommentId2\"));",
                  "const foreignId = Number(pm.collectionVariables.get(\"foreignCommentId\"));",
                  "",
                  "pm.test(\"Ответ должен содержать код статуса 200 и данные в формате json\", function () {",
                  "    pm.response.to.have.status(200);   ",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Ответ содержит только комментарии целевого пользователя\", function () {",
                  "    const hasComment1 = responseJson.some(c => c.id === id1);",
                  "    pm.expect(hasComment1, \"Первый комментарий пользователя должен быть в ответе\").to.be.true;",
                  "",
                  "    const hasComment2 = responseJson.some(c => c.id === id2);",
                  "    pm.expect(hasComment2, \"Второй комментарий пользователя должен быть в ответе\").to.be.true;",
                  "",
                  "    const hasForeignComment = responseJson.some(c => c.id === foreignId);",
                  "    pm.expect(hasForeignComment, \"Комментарий чужого пользователя НЕ должен попасть в ответ\").to.be.false;",
                  "});",
                  "",
                  "pm.test(\"Количество комментариев в ответе совпадает с ожидаемым\", function () {",
                  "    pm.expect(responseJson.length).to.be.at.least(2);",
                  "});"
                ],
