        {
          "name": "Удаление своего комментария",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const source = pm.collectionVariables.get('responseArr');",
                  "const commentId = Number(pm.collectionVariables.get('commentId'));",
                  "const userId = pm.collectionVariables.get('uid');",
                  "",
                  "pm.test(\"Ответ должен содержать код статуса 204\", function () {",
                  "    pm.response.to.have.status(204);   ",
                  "});",
                  "",
                  "pm.test(\"Комментарий должен быть найден в списке до удаления\", function () {",
                  "    const isFoundBefore = source.some(comment => comment.id === commentId);",
                  "    pm.expect(isFoundBefore).to.be.true;",
                  "});",
                  "",
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get(\"baseUrl\") + `/users/${userId}/comments`,",
                  "    method: 'GET',",
                  "}, (error, response) => {",
                  "    pm.test(\"Комментарий не должен быть найден в списке после удаления\", function () {",
                  "        pm.expect(response).to.have.status(200);",
                  "",
                  "        const freshCommentsList = response.json();",
                  "        const isFoundAfter = freshCommentsList.some(comment => comment.id === commentId);",
                  "        pm.expect(isFoundAfter).to.be.false;",
                  "    });",
                  "});",
                  "",
                  "",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
